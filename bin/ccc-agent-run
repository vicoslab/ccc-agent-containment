#!/usr/bin/env python3
"""Trusted launcher: run a command inside a contained BranchFS agent session."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from ccc_agent.cli import main_run

if __name__ == "__main__":
    sys.exit(main_run(sys.argv[1:]))
